{{define "subject"}}Your ticket — {{.EventName}}{{end}}

{{define "html"}}<!DOCTYPE html>
<html lang="en" dir="ltr">
<head><meta charset="UTF-8"><title>Your ticket</title></head>
<body style="font-family:sans-serif;max-width:600px;margin:0 auto;padding:20px;color:#1a1a2e">
  <h1 style="color:#1a1a2e">Your ticket is ready</h1>
  <p>Hello{{with .HolderName}} {{.}}{{end}},</p>
  <p>Your ticket for <strong>{{.EventName}}</strong> has been issued.
     Please find the PDF attached to this email.</p>
  <table cellpadding="4" style="border-collapse:collapse;font-size:14px">
    <tr><td><strong>Event</strong></td><td>{{.EventName}}</td></tr>
    {{with .SessionStart}}<tr><td><strong>Session</strong></td><td>{{.}}</td></tr>{{end}}
    {{with .VenueName}}<tr><td><strong>Venue</strong></td><td>{{.}}</td></tr>{{end}}
    {{with .TierName}}<tr><td><strong>Tier</strong></td><td>{{.}}</td></tr>{{end}}
  </table>
  <p style="font-size:12px;color:#666">Ticket ID: {{.TicketID}}</p>
  <p style="font-size:12px;color:#666">Delivered to: {{.RecipientEmail}}</p>
  <hr>
  <p style="font-size:11px;color:#999">Arena Platform — automated delivery</p>
</body>
</html>{{end}}

{{define "text"}}Your ticket is ready

Hello{{with .HolderName}} {{.}}{{end}},

Your ticket for {{.EventName}} has been issued.
Please find the PDF attached to this email.

Event: {{.EventName}}
{{with .SessionStart}}Session: {{.}}
{{end}}{{with .VenueName}}Venue: {{.}}
{{end}}{{with .TierName}}Tier: {{.}}
{{end}}
Ticket ID: {{.TicketID}}
Delivered to: {{.RecipientEmail}}

Arena Platform — automated delivery
{{end}}
