# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
dist/
build/

# Test artifacts
*.test
*.out
coverage.txt
coverage.html
profile.cov
.gocache/

# Local env files (NEVER commit secrets)
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# AutoForge runtime (managed by the harness)
.autoforge/runtime/
.autoforge/state/
.autoforge/*.db
.autoforge/*.db-journal
.autoforge/*.db-shm
.autoforge/*.db-wal

# Local Postgres / Redis data volumes
data/postgres/
data/redis/

# Node.js (TypeScript client generation tooling)
node_modules/

# Exact-hash duplicate quarantine (deleted from git per feature #179;
# duplicates are recoverable from their KeptPath listed in
# 00_project_control/DEDUPLICATION_REPORT.csv). Path is ignored so
# accidental re-creation of the quarantine folder does not get committed.
99_archive_duplicates/

# Logs
*.log
logs/

# Playwright (legacy)
.playwright-cli/
.playwright/

# k6 load test results (generated artifacts; not source)
ops/loadtest/results/*.json
ops/loadtest/results/*.gz

# Shell-mishap artifacts: ignore stray dirs that come from broken
# PowerShell/bash paths like `cd C:Projectsarena_new` or `cd ...;C`.
# Real project paths never contain ';' on POSIX, and the duplicated
# "Projects*" prefix at the repo root is always an accident.
*\;*/
*\;*
Projectsarena_new/
/Projects*/
