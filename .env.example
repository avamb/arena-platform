# ============================================================
# arena_new — Backend Foundation Milestone
# ============================================================
# Copy this file to `.env` for local development.
# Production values are injected by Dokploy environment configuration.
# NEVER commit a real `.env` file.

# ---- Application ----
# One of: development | staging | production
APP_ENV=development
# Service name used in logs and tracing
APP_NAME=arena-api
# Semver populated by CI at build time
APP_VERSION=0.1.0-dev
# Git SHA populated by CI at build time
APP_COMMIT=local

# ---- HTTP server ----
HTTP_LISTEN_ADDR=:8080
# Maximum allowed request body in bytes (1 MiB default)
BODY_LIMIT_BYTES=1048576
# Per-request timeout in seconds
REQUEST_TIMEOUT_SECONDS=30
# Comma-separated allowlist of origins for CORS, or "*" for dev
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Database (PostgreSQL 17) ----
# pgx DSN
DATABASE_URL=postgres://arena:arena@postgres:5432/arena?sslmode=disable
DB_POOL_MIN_CONNS=2
DB_POOL_MAX_CONNS=20
DB_POOL_MAX_CONN_LIFETIME=1h
DB_POOL_MAX_CONN_IDLE_TIME=30m
# Set to true to log every SQL statement (slow; dev only)
DB_LOG_QUERIES=false

# ---- Redis (locks / hot caches; PostgreSQL remains source of truth) ----
REDIS_URL=redis://redis:6379/0

# ---- Auth (dev-only placeholder) ----
# Enable the dev placeholder IdentityProvider. Must be false in production —
# the boundary is wired to a real IdP in a later milestone.
ENABLE_DEV_AUTH=true
# HS256 signing secret for the dev stub IdentityProvider.
# Production swaps to RS256/asymmetric via the same AuthBoundary.
JWT_SIGNING_SECRET=dev-only-do-not-use-in-prod
JWT_ISSUER=arena-dev
JWT_AUDIENCE=arena-api
JWT_DEFAULT_TTL=1h

# ---- Idempotency ----
# Time-to-live for stored idempotency keys
IDEMPOTENCY_TTL=24h
# Maximum length of the Idempotency-Key header value
IDEMPOTENCY_KEY_MAX_LENGTH=255

# ---- Internationalization ----
# Default locale when negotiation finds no match
DEFAULT_LOCALE=en
# Comma-separated list of active locales (lookup ranges)
ACTIVE_LOCALES=ru,en

# ---- Observability ----
# slog level: debug | info | warn | error
LOG_LEVEL=info
# Output format: json | text  (production must be json)
LOG_FORMAT=text
# OpenTelemetry OTLP gRPC endpoint (host:port). Leave empty to disable.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=arena-api
OTEL_TRACES_SAMPLER_ARG=0.1

# ---- Worker ----
WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL=1s
WORKER_JOB_TIMEOUT=5m
WORKER_RETRY_BACKOFF_BASE=2s
WORKER_RETRY_BACKOFF_MAX=10m

# ---- Outbox dispatcher ----
OUTBOX_POLL_INTERVAL=2s
OUTBOX_BATCH_SIZE=50

# ---- Graceful shutdown ----
SHUTDOWN_TIMEOUT=20s
