{
  "name": "arena-new",
  "version": "0.1.0",
  "private": true,
  "description": "Backend foundation for arena_new multi-tenant ticketing platform",
  "scripts": {
    "gen-ts-client": "node scripts/gen-ts-client.mjs",
    "check-ts": "tsc --noEmit apps/backend/openapi/clients/ts/index.d.ts",
    "admin:install": "npm --prefix apps/admin-web install",
    "admin:dev": "npm --prefix apps/admin-web run dev",
    "admin:build": "npm --prefix apps/admin-web run build",
    "admin:test": "npm --prefix apps/admin-web run test",
    "admin:type-check": "npm --prefix apps/admin-web run type-check",
    "admin:smoke-guardrails": "node scripts/admin-smoke-guardrails.mjs",
    "admin:smoke": "node scripts/admin-smoke-guardrails.mjs && npm --prefix apps/admin-web run test && npm --prefix apps/admin-web run build && npm run check-ts"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.16.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.8.3"
  }
}
